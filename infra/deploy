#!/usr/bin/env bash
# nuc/apps/burpee/deploy
# Usage: ./nuc/apps/burpee/deploy user@nuc
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/config"

TARGET="${1:?usage: $0 user@nuc}"

log() { echo "==> $*"; }

log "Building assets"
MIX_ENV=prod mix assets.deploy

log "Building release"
MIX_ENV=prod mix release --overwrite

log "Uploading to ${TARGET}:${HOST_DEPLOY_DIR}"
ssh "$TARGET" "doas mkdir -p ${HOST_DEPLOY_DIR}"

rsync -az --delete \
  --rsync-path="doas rsync" \
  "_build/prod/rel/${APP}/" \
  "${TARGET}:${HOST_DEPLOY_DIR}/"
ssh "$TARGET" "doas chown -R ${JAIL}:${JAIL} ${HOST_DEPLOY_DIR}"

log "Syncing videos"
VIDEO_DIR="/jails/${JAIL}/var/lib/${APP}/videos"
ssh "$TARGET" "doas mkdir -p ${VIDEO_DIR}"
rsync -az \
  --rsync-path="doas rsync" \
  --include="*_h264.mp4" --exclude="*" \
  "videos/" \
  "${TARGET}:${VIDEO_DIR}/"
ssh "$TARGET" "doas chown -R ${JAIL}:${JAIL} ${VIDEO_DIR}"

log "Running migrations"
ssh "$TARGET" "
  doas jexec ${JAIL} sh -c '
    set -a && . /etc/${JAIL}/env && set +a
    ${JAIL_DEPLOY_DIR}/bin/${APP} eval \"${MODULE}.Release.migrate()\"
  '
"

log "Restarting service"
ssh "$TARGET" "doas jexec ${JAIL} service ${APP} restart \
  || doas jexec ${JAIL} service ${APP} start"

log "Status:"
ssh "$TARGET" "doas jexec ${JAIL} service ${APP} status"

log ""
log "Logs: ssh ${TARGET} 'tail -f /jails/${JAIL}/var/log/${JAIL}/${APP}.log'"
